# ── Database (Supabase Postgres) ──────────────────────────────────────────
# Pooled connection — for runtime queries
DATABASE_URL="postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection — for prisma migrate / seed only
DIRECT_URL="postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:5432/postgres"

# ── Auth.js v5 ────────────────────────────────────────────────────────────
AUTH_SECRET=                # openssl rand -base64 32
AUTH_URL=http://localhost:3000

# ── Supabase (Storage) ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=  # Server-side only — never NEXT_PUBLIC_

# ── Resend (contact form notifications) ───────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@muem.com
ADMIN_NOTIFY_EMAIL=         # Where contact submissions get sent

# ── Admin seed (used once by prisma/seed.ts) ──────────────────────────────
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
