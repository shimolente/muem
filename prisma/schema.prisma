// Muem Studio CMS — data model
// See CLAUDE.md "Entities" section for field rationale.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────
enum Role {
  ADMIN
}

// Studio / Property / Furniture categories are admin-managed at runtime via the
// Category model (below), so they are plain String columns — not enums.
// FeaturedCategory stays an enum: the 3 homepage tabs are a fixed structure.
enum FeaturedCategory {
  Residential
  Hospitality
  Commercial
}

enum ProjectStatus {
  Completed
  InProgress
  Concept
}

// Which content type a Category row belongs to.
enum CategoryKind {
  STUDIO
  PROPERTY
  FURNITURE
}

// How a ContactSubmission was created:
//   GENERAL   → public contact form (/api/contact)
//   DEVELOPER → "Contact the developer" modal on a property page
enum SubmissionKind {
  GENERAL
  DEVELOPER
}

// ── Auth (single admin) ────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Studio Projects ────────────────────────────────────────────────────────
model StudioProject {
  id          String           @id @default(cuid())
  slug        String           @unique
  title       String
  subtitle    String?
  description String?
  location    String?
  topology    String?
  category    String?          // → Category(kind: STUDIO).label
  size        String?
  year        Int?
  status      ProjectStatus    @default(Completed)
  images      String[]
  featured    Boolean          @default(false)
  sortOrder   Int              @default(0)
  publishedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  featuredSlots FeaturedSlot[]

  @@index([deletedAt, publishedAt])
  @@index([sortOrder])
  @@index([category])
}

// ── Properties (real estate) ───────────────────────────────────────────────
model Property {
  id          String            @id @default(cuid())
  slug        String            @unique
  title       String
  subtitle    String?
  description String?
  location    String?
  topology    String?           // → Category(kind: PROPERTY).label
  size        String?
  year        Int?
  status      ProjectStatus     @default(Completed)
  priceFrom   String?
  bedrooms    Int?
  bathrooms   Int?
  carPort     Int?
  unitsTotal  Int?
  unitsSold   Int               @default(0)
  developerPhone String?
  images      String[]
  featured    Boolean           @default(false)
  sortOrder   Int               @default(0)
  publishedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([deletedAt, publishedAt])
  @@index([sortOrder])
}

// ── Furniture ──────────────────────────────────────────────────────────────
model Furniture {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  collection  String?
  category    String            // → Category(kind: FURNITURE).label
  material    String?
  price       String?
  subtitle    String?
  description String?
  dimensions  String?
  finish      String?
  leadTime    String?
  origin      String?
  images      String[]
  featured    Boolean           @default(false)
  sortOrder   Int               @default(0)
  publishedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([deletedAt, publishedAt])
  @@index([sortOrder])
  @@index([category])
}

// ── Featured Projects (homepage bento selection) ───────────────────────────
model FeaturedSlot {
  id        String           @id @default(cuid())
  category  FeaturedCategory
  projectId String
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())

  project StudioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([category, projectId])
  @@index([category, sortOrder])
}

// ── Categories (admin-managed, per content kind) ────────────────────────────
// Drives both admin form selects and public filter bars. An entity stores the
// category `label` string in its category/topology column (matched directly by
// the public filters). Renames cascade to entity rows in the update action.
model Category {
  id        String       @id @default(cuid())
  kind      CategoryKind
  label     String
  slug      String
  sortOrder Int          @default(0)
  deletedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([kind, slug])
  @@index([kind, sortOrder])
}

// ── Site settings (single row) ──────────────────────────────────────────────
// Editable from /admin/settings; read by the public site (socials, stat
// counters, contact details). One row, id = "singleton".
model SiteSettings {
  id              String   @id @default("singleton")
  socials         Json     @default("[]") // [{ label, href }]
  coconutsShared  Int      @default(84)
  aboutStats      Json     @default("[]") // [{ value, label, tags: string[] }]
  contactEmail    String?
  contactWhatsapp String?
  contactLocation String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Contact form submissions ───────────────────────────────────────────────
model ContactSubmission {
  id         String         @id @default(cuid())
  kind       SubmissionKind @default(GENERAL)
  name       String
  email      String
  phone      String?        // captured by the developer-contact modal
  lookingFor String
  message    String
  // Denormalized property reference for DEVELOPER submissions (kept as strings,
  // like `lookingFor`, so the record survives property renames / soft-deletes).
  propertySlug  String?
  propertyTitle String?
  read       Boolean        @default(false)
  repliedAt  DateTime?
  createdAt  DateTime       @default(now())

  @@index([read, createdAt])
  @@index([kind, createdAt])
}
