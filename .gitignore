# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# stale build output
/dist

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code (session data + worktrees — worktrees are embedded git repos)
.claude/projects/
.claude/worktrees/

# raw source image dumps (not site assets)
/furniture_images/
/property_images/

# scratch / reference
/wipe-example/
